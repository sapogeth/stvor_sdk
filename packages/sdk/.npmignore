# NPM ignore file - excludes dev/build artifacts
# These files shouldn't be included in the published npm package

# Source files (compiled to dist)
src/
*.ts
!*.d.ts

# Build artifacts and duplication
dist/src/
dist/facade/__tests__/
dist/__tests__/

# Development & testing
__tests__/
*.test.ts
*.bench.ts
test*.js
*.spec.ts
.github/
.gitignore
.git

# Configuration files
tsconfig.json
tsconfig.*.json
*.tsbuildinfo
.eslintrc*
.prettierrc*

# Build scripts
postbuild-fix-extensions.*
build-cjs.*
*.sh

# Documentation artifacts
node_modules/
pnpm-lock.yaml
package-lock.json
yarn.lock
.env*

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Misc
coverage/
dist/**/*.map
*.tmp
