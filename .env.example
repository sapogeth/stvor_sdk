# STVOR API Configuration
# Copy this file to .env and fill in your values

# Database
DB_HOST=localhost
DB_PORT=5433
DB_USER=postgres
DB_PASSWORD=stvor123
DB_NAME=stvor

# Redis (for replay protection in production)
REDIS_URL=redis://localhost:6379
REDIS_REPLAY_URL=redis://localhost:6379
REDIS_REPLAY_PREFIX=stvor:replay:
REDIS_REPLAY_TTL=300

# Server
NODE_ENV=development
PORT=3001

# WebSocket Relay
RELAY_PORT=3002
